import sys
from PyQt6.QtWidgets import (QApplication, QWidget, QVBoxLayout, QHBoxLayout, 
                             QFormLayout, QLabel, QPushButton, QLineEdit, 
                             QCheckBox, QComboBox, QSlider, QProgressBar, QMessageBox)
from PyQt6.QtCore import Qt

class BasicWidgetsWindow(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Завдання 1 & 2: Базові віджети та сигнали")
        self.setMinimumSize(400, 300)
        self.init_ui()

    def init_ui(self):
        main_layout = QVBoxLayout()
        
        # Завдання 1: Використання QFormLayout (перший тип layout)
        form_layout = QFormLayout()
        
        self.name_input = QLineEdit()
        self.name_input.setPlaceholderText("Введіть ваше ім'я...")
        self.name_input.setToolTip("Тут потрібно ввести текст")
        
        self.age_combo = QComboBox()
        self.age_combo.addItems([str(i) for i in range(18, 100)])
        
        self.terms_check = QCheckBox("Я погоджуюсь з умовами")
        
        form_layout.addRow("Ім'я:", self.name_input)
        form_layout.addRow("Вік:", self.age_combo)
        form_layout.addRow(self.terms_check)
        
        # Завдання 1: Вкладення QHBoxLayout у QVBoxLayout
        slider_layout = QHBoxLayout()
        self.slider = QSlider(Qt.Orientation.Horizontal)
        self.slider.setRange(0, 100)
        self.progress = QProgressBar()
        
        slider_layout.addWidget(QLabel("Рівень:"))
        slider_layout.addWidget(self.slider)
        slider_layout.addWidget(self.progress)
        
        # Кнопки
        btn_layout = QHBoxLayout()
        self.submit_btn = QPushButton("Підтвердити")
        self.reset_btn = QPushButton("Скинути")
        btn_layout.addWidget(self.submit_btn)
        btn_layout.addWidget(self.reset_btn)

        # Додавання в головний layout
        main_layout.addLayout(form_layout)
        main_layout.addLayout(slider_layout)
        main_layout.addLayout(btn_layout)
        self.setLayout(main_layout)

        # Завдання 2: Сигнали та слоти
        # 1. Вбудований сигнал
        self.slider.valueChanged.connect(self.progress.setValue)
        
        # 2. Лямбда-вираз
        self.terms_check.stateChanged.connect(
            lambda state: self.submit_btn.setEnabled(state == 2)
        )
        self.submit_btn.setEnabled(False) # Початковий стан

        # 3. Метод класу (Валідація)
        self.submit_btn.clicked.connect(self.validate_form)
        
        # 4. Скидання
        self.reset_btn.clicked.connect(self.reset_form)

    def validate_form(self):
        if not self.name_input.text():
            QMessageBox.warning(self, "Помилка", "Ім'я не може бути порожнім!")
        else:
            QMessageBox.information(self, "Успіх", f"Привіт, {self.name_input.text()}!")

    def reset_form(self):
        self.name_input.clear()
        self.slider.setValue(0)
        self.terms_check.setChecked(False)

if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = BasicWidgetsWindow()
    window.show()
    sys.exit(app.exec())
